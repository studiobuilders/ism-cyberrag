# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
SUPABASE_SECRET_KEY=your-supabase-secret-key-here

# ── Main LLM (for generating answers to questions) ────────
# Provider: 'groq' (cloud API) or 'ollama' (local/cloud)
LLM_PROVIDER=groq
LLM_MODEL_NAME=llama-3.1-8b-instant

# ── Evaluation LLM (for RAGAS metric scoring) ────────────
# Provider: 'groq' or 'ollama' (ollama local recommended to avoid rate limits)
EVAL_LLM_PROVIDER=ollama
EVAL_LLM_MODEL=llama3.1:8b

# ── Ollama Base URL ──────────────────────────────────────
# For local Ollama: http://localhost:11434
# For remote/cloud Ollama: set to your remote server URL
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq API Key ─────────────────────────────────────────
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ClearML
CLEARML_API_ACCESS_KEY=your-clearml-access-key-here
CLEARML_API_SECRET_KEY=your-clearml-secret-key-here
CLEARML_API_HOST=https://api.clear.ml
CLEARML_WEB_HOST=https://app.clear.ml
CLEARML_FILES_HOST=https://files.clear.ml
